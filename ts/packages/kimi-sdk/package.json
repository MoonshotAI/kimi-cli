{
  "name": "@moonshot-ai/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Kimi API",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@moonshot-ai/core": "workspace:^"
  }
}
