{
  "compilerOptions": {
    "target": "ES2022",
    "module": "preserve",
    "moduleResolution": "bundler",
    "lib": ["ES2023"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",

    "strict": true,
    "isolatedDeclarations": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "exactOptionalPropertyTypes": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": true,
    "skipLibCheck": true,

    "types": ["node"],

    "paths": {
      "@moonshot-ai/kosong": ["./packages/kosong/src/index.ts"],
      "@moonshot-ai/kaos": ["./packages/kaos/src/index.ts"],
      "@moonshot-ai/core": ["./packages/kimi-core/src/index.ts"],
      "@moonshot-ai/sdk": ["./packages/kimi-sdk/src/index.ts"],
      "@moonshot-ai/cli": ["./apps/kimi-cli/src/index.ts"],
      "@moonshot-ai/kimi-wire-mock": ["./mock/kimi-wire/src/index.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx",
    "packages/*/test/**/*.ts",
    "packages/*/test/**/*.tsx",
    "apps/*/src/**/*.ts",
    "apps/*/src/**/*.tsx",
    "apps/*/test/**/*.ts",
    "apps/*/test/**/*.tsx",
    "mock/*/src/**/*.ts",
    "mock/*/test/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "coverage", "packages/kosong/test/type-safety-negative.ts"]
}
